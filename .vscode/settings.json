{
    // Override the language association for .agent.md files so that VS Code's
    // prompts-diagnostics-provider does not validate them. The chat extension
    // discovers agents by path pattern (.github/agents/*.agent.md), not by
    // language ID, so all agents remain fully functional. This suppresses the
    // false-positive "tool renamed" and "unknown agent" diagnostics that
    // fluctuate in the Problems panel.
    "files.associations": {
        "*.agent.md": "markdown"
    },
    "chat.tools.terminal.autoApprove": {
        "npx prettier": true,
        "uv": true,
        "git add": true,
        "git commit": true,
        "pnpm": true,
        "buf": true,
        "git push": true,
        "gh": true,
        "git checkout": true,
        "git pull": true,
        "touch": true,
        "true": true,
        "pre-commit": true,
        "printf": true,
        "uniq": true,
        "git fetch": true,
        "git rebase": true,
        "git reset": true,
        "git restore": true,
        "read": true,
        "node": true,
        "gzip": true,
        "docker compose": true,
        "cp": true
    },
    "python.analysis.extraPaths": [
        "shared/a2a/python/src",
        "shared/a2a/python/.venv/lib/python3.12/site-packages",
        "shared/vector-store/python/src",
        "shared/vector-store/python/.venv/lib/python3.12/site-packages",
        "modules/group-i-signal-processing/sensory-input/src",
        "modules/group-i-signal-processing/sensory-input/.venv/lib/python3.12/site-packages",
        "modules/group-i-signal-processing/attention-filtering/src",
        "modules/group-i-signal-processing/attention-filtering/.venv/lib/python3.12/site-packages",
        "modules/group-i-signal-processing/perception/src",
        "modules/group-i-signal-processing/perception/.venv/lib/python3.12/site-packages",
        "modules/group-ii-cognitive-processing/memory/working-memory/src",
        "modules/group-ii-cognitive-processing/memory/working-memory/.venv/lib/python3.12/site-packages",
        "modules/group-ii-cognitive-processing/memory/short-term-memory/src",
        "modules/group-ii-cognitive-processing/memory/short-term-memory/.venv/lib/python3.12/site-packages",
        "modules/group-ii-cognitive-processing/memory/long-term-memory/src",
        "modules/group-ii-cognitive-processing/memory/long-term-memory/.venv/lib/python3.12/site-packages",
        "modules/group-ii-cognitive-processing/memory/episodic-memory/src",
        "modules/group-ii-cognitive-processing/memory/episodic-memory/.venv/lib/python3.12/site-packages",
        "modules/group-ii-cognitive-processing/affective/src",
        "modules/group-ii-cognitive-processing/affective/.venv/lib/python3.12/site-packages",
        "modules/group-ii-cognitive-processing/reasoning/src",
        "modules/group-ii-cognitive-processing/reasoning/.venv/lib/python3.12/site-packages",
        "modules/group-iii-executive-output/executive-agent/src",
        "modules/group-iii-executive-output/executive-agent/.venv/lib/python3.12/site-packages",
        "modules/group-iii-executive-output/agent-runtime/src",
        "modules/group-iii-executive-output/agent-runtime/.venv/lib/python3.12/site-packages",
        "modules/group-iii-executive-output/motor-output/src",
        "modules/group-iii-executive-output/motor-output/.venv/lib/python3.12/site-packages",
        "modules/group-iii-executive-output/.venv/lib/python3.12/site-packages"
    ],
    "python.analysis.ignore": [
        "shared/a2a/python/.venv/**",
        "shared/vector-store/python/.venv/**",
        "modules/group-i-signal-processing/sensory-input/.venv/**",
        "modules/group-i-signal-processing/attention-filtering/.venv/**",
        "modules/group-i-signal-processing/perception/.venv/**",
        "modules/group-ii-cognitive-processing/memory/working-memory/.venv/**",
        "modules/group-ii-cognitive-processing/memory/short-term-memory/.venv/**",
        "modules/group-ii-cognitive-processing/memory/long-term-memory/.venv/**",
        "modules/group-ii-cognitive-processing/memory/episodic-memory/.venv/**",
        "modules/group-ii-cognitive-processing/affective/.venv/**",
        "modules/group-ii-cognitive-processing/reasoning/.venv/**",
        "modules/group-iii-executive-output/executive-agent/.venv/**",
        "modules/group-iii-executive-output/agent-runtime/.venv/**",
